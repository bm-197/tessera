{
  "name": "tessera-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "sidecar": "go build -o electron/bin/tessera-sidecar ../cmd/tessera-sidecar",
    "dev": "npm run sidecar && concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.cjs\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "smoke": "npm run sidecar && vite build && electron scripts/smoke.cjs",
    "package": "npm run sidecar && vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "wait-on": "^8.0.1"
  }
}
